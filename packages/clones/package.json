{
  "name": "@rezzou/clones",
  "version": "0.2.0",
  "description": "Persistent git clone management",
  "author": "Pierre Demailly <pierredemailly.pro@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "test": "node --strip-types --experimental-test-module-mocks --test src/test/**/*.spec.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false,
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rezzou-project/rezzou.git",
    "directory": "packages/clones"
  },
  "dependencies": {
    "@rezzou/core": "*"
  }
}
