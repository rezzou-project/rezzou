{
  "extends": "@openally/config.typescript/esm-ts-next",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "references": [
    { "path": "../sdk/tsconfig.build.json" }
  ],
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/test/**/*",
    "dist"
  ]
}
