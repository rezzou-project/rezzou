{
  "name": "@rezzou/cli",
  "version": "0.1.0",
  "description": "CLI for Rezzou. Bulk maintenance operations across repositories",
  "author": "Pierre Demailly <pierredemailly.pro@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "rezzou": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
